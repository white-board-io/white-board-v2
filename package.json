{
  "name": "white-board-v2",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-types": "turbo run check-types",
    "check-versions": "check-dependency-version-consistency --dep-type=dependencies,devDependencies,optionalDependencies,peerDependencies,resolutions ."
  },
  "devDependencies": {
    "check-dependency-version-consistency": "^6.0.0",
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
